# ============================================
# JOB HUNTER BOT — Full Configuration
# ============================================
# Copy this file to .env and fill in your values

# ── GEMINI ─────────────────────────────────────
# Get yours free: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── NOTION ─────────────────────────────────────
# Create integration: https://www.notion.so/my-integrations
# Then share your database page with the integration
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── GMAIL (IMAP) ──────────────────────────────
# Use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# ── LINKEDIN (for Easy Apply) ─────────────────
# Your LinkedIn login credentials
# The bot uses Playwright to automate Easy Apply
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# ── FILES ──────────────────────────────────────
# Path to your master resume PDF
MASTER_RESUME_PATH=master_resume.pdf
# Path to your LinkedIn connections CSV export
CONNECTIONS_CSV_PATH=connections.csv
# Path to your resume tailoring prompt (the instructions from your Gemini Gem)
RESUME_PROMPT_PATH=resume_prompt.txt

# ── SEARCH SETTINGS ───────────────────────────
SEARCH_LOCATIONS=Georgia,Remote
DAYS_BACK=2

# ── SCORING & APPLY SETTINGS ──────────────────
# Jobs scoring >= AUTO_APPLY_MIN get auto-applied
AUTO_APPLY_MIN=7
# Jobs scoring >= FLAG_MIN but < AUTO_APPLY_MIN get flagged for review
FLAG_MIN=6

# ── SCHEDULE ───────────────────────────────────
# Time to run the job scrape+apply pipeline daily
PIPELINE_TIME=08:00
# How often to check Gmail for updates (in minutes)
GMAIL_CHECK_INTERVAL=60
